<view class="container">
  <view class="upload-container">
    <!-- 预览区域 -->
    <block wx:if="{{previewImages.length > 0}}">
      <image 
        class="preview-image" 
        src="{{previewImages}}" 
        mode="aspectFill"
        bind:tap="handleUpload"
      />
    </block>
    
    <!-- 上传按钮 -->
    <block wx:else>
      <button 
        class="upload-button {{customClass}}"
        bind:tap="handleUpload"
        loading="{{loading}}"
      >
        {{buttonText}}
      </button>
    </block>
  </view>
</view>