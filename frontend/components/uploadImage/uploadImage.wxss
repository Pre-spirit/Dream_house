.upload-container {
  display: flex;
  justify-content: center;
  align-items: center;
}

.preview-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}

.upload-button {
  width: 200rpx;
  height: 200rpx;
  line-height: 200rpx;
  font-size: 28rpx;
  padding: 0;
  background: #f5f5f5;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
}

.upload-button::after {
  border: none;
}