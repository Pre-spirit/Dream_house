<view class="input-dialog-container {{isShow?'show':'hide'}}">
  <view class="dialog-header">
      <text>{{title}}</text>
  </view>
  <view class="dialog-content">
      <input type="text" placeholder="{{placeholderText}}" bind:input="onInputChange"/>
      <input type="number" placeholder="{{placeholderScore}}" bind:input="onInputScore"/>
  </view>
  <view class="dialog-footer">
      <button bind:tap="confirm" size="mini" class="dialog-q">确定</button>
      <button bind:tap="cancel" size="mini" class="dialog-x">取消</button>
  </view>
</view>