/* 九宫格样式 */
.grid-container {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.grid-item {
  position: relative;
  width: 33.33%;
  height: 0;
  padding-bottom: 33.33%; /* 保持正方形 */
  box-sizing: border-box;
  overflow: hidden;
  border: 6rpx solid #ffffff; /* 白色间隔 */
}

.grid-image {
  position: absolute;
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.grid-text {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  color: white;
  font-size: 20rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
}

.grid-text-s {
  position: absolute;
  bottom: 0;
  right: 0;
  padding: 16rpx;
  color: white;
  font-size: 24rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
}

/* 点击效果 */
.grid-item:active .grid-image {
  transform: scale(0.95);
}


