/* pages/message/message.wxss */
.header {
  height: 50px;
  background-color: #747ca7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cross-button {
  position: relative;
  width: 40px;
  height: 40px;
  cursor: pointer;
}

.cross-button::before,
.cross-button::after {
  content: '';
  position: absolute;
  background-color: #e2e5e9;
}

.cross-button::before {
  width: 8px;
  height: 40px;
  left: 16px;
}

.cross-button::after {
  width: 40px;
  height: 8px;
  top: 16px;
}

.swiper-view {
  height: 400rpx;
}

.swiper-view image {
  height: 100%;
  width: 100%;
}

